import React, { useState, useMemo, useEffect, useRef, useCallback } from "react";
import { motion } from "framer-motion";
import { Scissors, MousePointer2, Plus, Trash2, Palette, PaintBucket, HelpCircle, X, Maximize, SunDim, Calendar, ListTodo, Circle, CheckCircle2 } from "lucide-react";

const baseYear = 2026;
